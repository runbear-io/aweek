node_modules/
.aweek/
.omc/
.ouroboros*
*.log
.DS_Store
# Claude Code local artifacts — per-user settings, lock files, and
# worktree checkouts. Shared state (.claude/agents/, .claude/commands/,
# .claude/settings.json) stays tracked so the plugin/subagent surface
# travels with the repo.
.claude/settings.local.json
.claude/*.lock
.claude/worktrees/
.env

# SPA build output — Vite writes the production bundle into
# `src/serve/spa/dist/`. Keeping it out of git stops every rebuild from
# churning the diff. The npm publish flow rebuilds it via the
# `prepublishOnly` script in package.json, so the published tarball
# still ships a fresh bundle. Local contributors should run
# `pnpm build` once after clone before `aweek serve`.
src/serve/spa/dist/

# Top-level build output — `pnpm build` compiles `bin/` + `src/` to
# `dist/` for the npm tarball, and copies the SPA bundle in. Same
# publish-time-only rationale as the SPA dist above.
dist/

# VitePress docs site — `pnpm docs:dev` writes a cache and `pnpm
# docs:build` writes the static bundle. Both are regenerated by the
# `docs.yml` workflow on every push to main, so neither belongs in git.
docs/.vitepress/cache/
docs/.vitepress/dist/
